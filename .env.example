# ============================================================
#  Omago – CVE Intelligence Assistant  |  Environment Config
# ============================================================
# Copy this file to .env and fill in your real keys.
# NEVER commit .env to GitHub – it is listed in .gitignore.

# ── Groq API (LLM backend – Llama 3.1-70B) ──────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── NVD API (National Vulnerability Database) ───────────────
# Optional but raises rate limit from 5 → 50 req/30s
# Register at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=your_nvd_api_key_here

# ── App Settings ─────────────────────────────────────────────
# Username shown in dashboard greeting
APP_USER_NAME=Yomna

# Max tokens for Groq completions
GROQ_MAX_TOKENS=1024

# Groq model to use
GROQ_MODEL=llama-3.3-70b-versatile
